<bg>
	<vertical pad-left="3" pad-right="3" pad-top="2" pad-bottom="2" spacing="2">
		<horizontal spacing="2">
			<button text='~main-tab-text' on-click='show-main' preferred-width='18' />
			<button text='~orbcontrols-tab-text' on-click='show-orbcontrols' preferred-width='24' />
			<button text='~tiktok-tab-text' on-click='show-tiktok' preferred-width='16' />
			<button text='~about-tab-text' on-click='show-about' preferred-width='16' />
		</horizontal>

		<vertical pad-left="8" pad-right="8" pad-top="1" spacing="0.5">
			<text text='~title-text' align='Center' font-size='6' />
			<text text='~subtitle-text' align='Center' font-size='3' />

			<text text='~version-label' font-size='3' />
			<text text='~version-value' font-size='3' />

			<text text='~features-label' font-size='3' />
			<text text='~feature-1' font-size='2.6' />
			<text text='~feature-2' font-size='2.6' />
			<text text='~feature-3' font-size='2.6' />
			<text text='~feature-4' font-size='2.6' />
			<text text='~feature-5' font-size='2.6' />
			<text text='~feature-6' font-size='2.6' />
			<text text='~feature-7' font-size='2.6' />

			<text text='~how-label' font-size='3' />
			<text text='~how-1' font-size='2.6' />
			<text text='~how-2' font-size='2.6' />
			<text text='~how-3' font-size='2.6' />
			<text text='~how-4' font-size='2.6' />

			<text text='~credits-label' font-size='3' />
			<text text='~credit-1' font-size='2.6' />

			<text text='' font-size='1' />
			<text text='' font-size='1' />

			<button text='~discord-button-text' on-click='open-discord' preferred-width='28' />
		</vertical>
	</vertical>
</bg>