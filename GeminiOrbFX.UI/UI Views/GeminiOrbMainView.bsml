<vertical spacing="3" pad="6">

	<horizontal spacing="1" align="Center">

		<button id="main-tab-button"
				text="~main-tab-text"
				on-click="show-main"
				width="18"
				preferred-height="8" />

		<button id="orbcontrols-tab-button"
				text="~orbcontrols-tab-text"
				on-click="show-orbcontrols"
				width="24"
				preferred-height="8" />

		<button id="tiktok-tab-button"
				text="~tiktok-tab-text"
				on-click="show-tiktok"
				width="18"
				preferred-height="8" />

		<button id="about-tab-button"
				text="~about-tab-text"
				on-click="show-about"
				width="18"
				preferred-height="8" />

	</horizontal>

	<!-- Spacer to push GeminiOrbFX title down -->
	<vertical preferred-height="8"/>

	<vertical spacing="3" align="Center">

		<text text="~title-text"
			  font-size="7"
			  align="Center" />

		<text text="System Status"
			  font-size="4.8"
			  align="Center" />

	</vertical>

	<text text="──────────────"
		  align="Center" />

	<vertical spacing="3" align="Center">

		<horizontal spacing="4" align="Center">

			<text text="HTTP Orb"
				  width="24"
				  align="Left" />

			<text text="~http-connection-state"
				  width="16"
				  align="Right" />

		</horizontal>

		<horizontal spacing="4" align="Center">

			<text text="Service"
				  width="24"
				  align="Left" />

			<text text="~tiktok-connection-state"
				  width="16"
				  align="Right" />

		</horizontal>

		<horizontal spacing="4" align="Center">

			<text text="User"
				  width="24"
				  align="Left" />

			<text text="~tiktok-username"
				  width="16"
				  align="Right" />

		</horizontal>

		<horizontal spacing="4" align="Center">

			<text text="Queue"
				  width="24"
				  align="Left" />

			<text text="~queue-count"
				  width="16"
				  align="Right"
				  font-size="3.6" />

		</horizontal>

	</vertical>

	<vertical spacing="2" align="Center">

		<button text="~clear-queue-button-text"
				on-click="clear-queue"
				interactable="~can-clear-queue"
				width="16" />

	</vertical>

	<text text="──────────────"
		  align="Center" />

	<vertical spacing="2" align="Center">

		<button text="~orb-test-button-text"
				on-click="toggle-orb-test"
				width="16" />

		<text text="~orb-test-message"
			  font-size="3"
			  align="Center" />

	</vertical>

</vertical>