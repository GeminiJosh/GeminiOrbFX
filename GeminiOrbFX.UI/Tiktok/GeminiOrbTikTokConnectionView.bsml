<vertical spacing="3" pad="6">

	<horizontal spacing="1" align="Center">
		<button text="~main-tab-text"
				on-click="show-main"
				width="18"
				preferred-height="8" />

		<button text="~orbcontrols-tab-text"
				on-click="show-orbcontrols"
				width="24"
				preferred-height="8" />

		<button text="~tiktok-tab-text"
				on-click="show-tiktok"
				width="18"
				preferred-height="8" />

		<button text="~about-tab-text"
				on-click="show-about"
				width="18"
				preferred-height="8" />
	</horizontal>

	<horizontal spacing="1" align="Center">
		<button text="~connection-subtab-text"
				on-click="show-connection-subtab"
				width="18"
				preferred-height="8" />

		<button text="~triggers-subtab-text"
				on-click="show-triggers-subtab"
				width="18"
				preferred-height="8" />

		<button text="~giftsettings-subtab-text"
				on-click="show-giftsettings-subtab"
				interactable="~gift-settings-enabled"
				width="24"
				preferred-height="8" />

		<button text="~debug-subtab-text"
				on-click="show-debug-subtab"
				width="18"
				preferred-height="8" />
	</horizontal>

	<horizontal spacing="4" align="Center">

		<vertical spacing="2" width="22">
			<text text="~relay-mode-label"
				  align="Left" />
			<text text="Username"
				  align="Left" />
			<text text="Service"
				  align="Left" />
		</vertical>

		<vertical spacing="2" width="30">
			<button text="~relay-mode-text"
					on-click="cycle-relay-mode"
					width="30"
					preferred-width="30"
					preferred-height="8" />

			<string-setting text=""
							value="tiktok-username"
							on-change="tiktok-username-changed"
							apply-on-change="false"
							interactable="~relay-username-enabled"
							width="30"
							preferred-width="30" />

			<text text="~tiktok-status"
				  align="Left" />
		</vertical>

	</horizontal>

	<text text="~relay-mode-description"
		  align="Center"
		  font-size="2.5" />

	<horizontal spacing="6" align="Center">

		<button text="~connect-button-text"
				on-click="connect-tiktok"
				interactable="~relay-connect-enabled"
				width="18"
				preferred-height="8" />

		<button text="~disconnect-button-text"
				on-click="disconnect-tiktok"
				width="18"
				preferred-height="8" />

	</horizontal>

</vertical>