<vertical spacing="3" pad="6">

	<horizontal spacing="1" align="Center">
		<button text="~main-tab-text"
				on-click="show-main"
				width="18"
				preferred-height="8" />

		<button text="~orbcontrols-tab-text"
				on-click="show-orbcontrols"
				width="24"
				preferred-height="8" />

		<button text="~tiktok-tab-text"
				on-click="show-tiktok"
				width="18"
				preferred-height="8" />

		<button text="~about-tab-text"
				on-click="show-about"
				width="18"
				preferred-height="8" />
	</horizontal>

	<horizontal spacing="1" align="Center">
		<button text="~connection-subtab-text"
				on-click="show-connection-subtab"
				width="18"
				preferred-height="8" />

		<button text="~triggers-subtab-text"
				on-click="show-triggers-subtab"
				width="18"
				preferred-height="8" />

		<button text="~giftsettings-subtab-text"
				on-click="show-giftsettings-subtab"
				interactable="~gift-settings-enabled"
				width="24"
				preferred-height="8" />

		<button text="~debug-subtab-text"
				on-click="show-debug-subtab"
				width="18"
				preferred-height="8" />
	</horizontal>

	<horizontal spacing="4" align="Center">

		<vertical spacing="1" width="22">
			<text text="Gift Permission"
				  align="Left" />

			<text text="Gift Mode"
				  align="Left" />

			<text text="~gift-name-label-text"
				  align="Left" />

			<text text="~gift-min-coins-label-text"
				  align="Left" />
		</vertical>

		<vertical spacing="1" width="30">
			<button text="~gift-permission-text"
					on-click="cycle-gift-permission"
					width="30"
					preferred-width="30"
					preferred-height="8" />

			<button text="~gift-mode-text"
					on-click="cycle-gift-mode"
					width="30"
					preferred-width="30"
					preferred-height="8" />

			<string-setting text=""
							value="gift-name-text"
							on-change="gift-name-text-changed"
							apply-on-change="true"
							interactable="~gift-name-interactable"
							width="30"
							preferred-width="30" />

			<string-setting text=""
							value="gift-min-coins-text"
							on-change="gift-min-coins-text-changed"
							apply-on-change="true"
							interactable="~gift-min-coins-interactable"
							width="30"
							preferred-width="30" />
		</vertical>

	</horizontal>

</vertical>